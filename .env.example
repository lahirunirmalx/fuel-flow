# Netlify only: set GEMINI_API_KEY in Netlify → Site configuration → Environment variables
# Scope must include Functions. Do not commit real keys.

GEMINI_API_KEY=""

# Optional: for `npx netlify dev` locally, create .env with GEMINI_API_KEY (Netlify CLI loads it).

# --- Optional function hardening (all optional; sensible defaults if unset) ---
# RATE_LIMIT_DISABLED=true          # disable in-memory limits (e.g. local stress test)
# RATE_LIMIT_WINDOW_MS=60000       # sliding window length (ms)
# RATE_LIMIT_GENERATE_FACT_MAX=30  # max GET /api/generate-fact per client IP per window
# RATE_LIMIT_FUEL_PRICES_MAX=15    # max POST /api/fuel-prices per client IP per window
# GENERATE_FACT_MAX_CHARS=4000     # truncate model text in JSON response
# FUEL_PRICE_NAME_MAX_CHARS=80
# FUEL_SOURCE_SUMMARY_MAX_CHARS=500
